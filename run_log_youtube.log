-----tool_environment_create Start-----
{"environment_name": "youtube_video_analyzer", "pip_requirements": ["yt-dlp>=2024.8.6","openai-whisper>=20231117","ffmpeg-python>=0.2.0","requests>=2.31.0","beautifulsoup4>=4.12.0","opencv-python>=4.8.0"], "tool_py_file_content": "import os\nimport subprocess\nimport tempfile\nimport json\nimport regex as re\nfrom pathlib import Path\nimport whisper\nimport yt_dlp\nimport ffmpeg\n\ndef download_youtube_video(url, output_path=None):\n    \"\"\"Download YouTube video and return the file path\"\"\"\n    if output_path is None:\n        output_path = tempfile.mkdtemp()\n    \n    ydl_opts = {\n        'format': 'best[height<=720]',  # Limit resolution to save bandwidth\n        'outtmpl': os.path.join(output_path, '%(title)s.%(ext)s'),\n        'writesubtitles': True,\n        'writeautomaticsub': True,\n        'subtitleslangs': ['en'],\n    }\n    \n    try:\n        with yt_dlp.YoutubeDL(ydl_opts) as ydl:\n            info = ydl.extract_info(url, download=True)\n            video_title = info['title']\n            video_ext = info['ext']\n            video_path = os.path.join(output_path, f\"{video_title}.{video_ext}\")\n            \n            return {\n                'video_path': video_path,\n                'title': video_title,\n                'duration': info.get('duration', 0),\n                'upload_date': info.get('upload_date', ''),\n                'description': info.get('description', ''),\n                'info': info\n            }\n    except Exception as e:\n        return {'error': str(e)}\n\ndef extract_audio_from_video(video_path, audio_path=None):\n    \"\"\"Extract audio from video file\"\"\"\n    if audio_path is None:\n        audio_path = video_path.rsplit('.', 1)[0] + '.wav'\n    \n    try:\n        (\n            ffmpeg\n            .input(video_path)\n            .output(audio_path, acodec='pcm_s16le', ac=1, ar='16000')\n            .overwrite_output()\n            .run(quiet=True)\n        )\n        return {'audio_path': audio_path}\n    except Exception as e:\n        return {'error': str(e)}\n\ndef transcribe_audio_with_whisper(audio_path):\n    \"\"\"Transcribe audio using OpenAI Whisper\"\"\"\n    try:\n        # Load the model\n        model = whisper.load_model(\"small\")  # Using small model for balance of speed/accuracy\n        \n        # Transcribe the audio\n        result = model.transcribe(audio_path, verbose=True, word_timestamps=True)\n        \n        return {\n            'text': result['text'],\n            'segments': result['segments'],\n            'language': result['language']\n        }\n    except Exception as e:\n        return {'error': str(e)}\n\ndef search_youtube_videos(query, max_results=10):\n    \"\"\"Search for YouTube videos\"\"\"\n    ydl_opts = {\n        'quiet': True,\n        'no_warnings': True,\n        'extract_flat': True,\n    }\n    \n    search_query = f\"ytsearch{max_results}:{query}\"\n    \n    try:\n        with yt_dlp.YoutubeDL(ydl_opts) as ydl:\n            search_results = ydl.extract_info(search_query, download=False)\n            \n            videos = []\n            for entry in search_results['entries']:\n                videos.append({\n                    'title': entry.get('title', ''),\n                    'url': f\"https://www.youtube.com/watch?v={entry['id']}\",\n                    'id': entry['id'],\n                    'duration': entry.get('duration', 0),\n                    'uploader': entry.get('uploader', ''),\n                    'upload_date': entry.get('upload_date', '')\n                })\n            \n            return {'videos': videos}\n    except Exception as e:\n        return {'error': str(e)}\n\ndef analyze_transcript_for_dinosaur_number(transcript_segments):\n    \"\"\"Analyze transcript to find number mentioned after dinosaurs are first shown\"\"\"\n    try:\n        text_segments = []\n        \n        # Extract text and timestamps from segments\n        for segment in transcript_segments:\n            text_segments.append({\n                'start': segment['start'],\n                'end': segment['end'],\n                'text': segment['text'].strip()\n            })\n        \n        # Find the first mention of dinosaurs\n        dinosaur_keywords = ['dinosaur', 'dinosaurs', 'dino', 'prehistoric', 'reptile', 'extinct']\n        dinosaur_segment_index = -1\n        \n        for i, segment in enumerate(text_segments):\n            text_lower = segment['text'].lower()\n            if any(keyword in text_lower for keyword in dinosaur_keywords):\n                dinosaur_segment_index = i\n                break\n        \n        if dinosaur_segment_index == -1:\n            return {'error': 'No mention of dinosaurs found in transcript'}\n        \n        # Look for numbers in segments after the dinosaur mention\n        number_patterns = [\n            r'\\b(\\d+)\\b',  # Simple numbers\n            r'\\b(one|two|three|four|five|six|seven|eight|nine|ten|eleven|twelve|thirteen|fourteen|fifteen|sixteen|seventeen|eighteen|nineteen|twenty|thirty|forty|fifty|sixty|seventy|eighty|ninety|hundred|thousand|million|billion)\\b',  # Written numbers\n        ]\n        \n        found_numbers = []\n        \n        # Search in the next few segments after dinosaur mention\n        for i in range(dinosaur_segment_index, min(len(text_segments), dinosaur_segment_index + 10)):\n            segment_text = text_segments['text']\n            \n            for pattern in number_patterns:\n                matches = re.finditer(pattern, segment_text, re.IGNORECASE)\n                for match in matches:\n                    number_text = match.group(1)\n                    found_numbers.append({\n                        'segment_index': i,\n                        'number': number_text,\n                        'context': segment_text,\n                        'timestamp': text_segments[i]['start']\n                    })\n        \n        return {\n            'dinosaur_segment_index': dinosaur_segment_index,\n            'dinosaur_context': text_segments[dinosaur_segment_index]['text'],\n            'found_numbers': found_numbers,\n            'all_segments': text_segments\n        }\n        \n    except Exception as e:\n        return {'error': str(e)}\n\ndef find_we_are_stars_video():\n    \"\"\"Search specifically for 'We Are Stars' 360 VR video from March 2018 with Andy Serkis\"\"\"\n    search_queries = [\n        \"We Are Stars 360 VR Andy Serkis March 2018\",\n        \"We Are Stars planetarium 360 degree NSC Creative\",\n        \"We Are Stars VR experience Andy Serkis narrator\",\n        \"We Are Stars 360 video planetarium show dinosaurs\"\n    ]\n    \n    all_results = []\n    \n    for query in search_queries:\n        results = search_youtube_videos(query, 5)\n        if 'videos' in results:\n            all_results.extend(results['videos'])\n    \n    # Filter results to find the most likely candidate\n    filtered_results = []\n    for video in all_results:\n        title_lower = video['title'].lower()\n        if ('we are stars' in title_lower or 'stars' in title_lower) and \\\n           ('360' in title_lower or 'vr' in title_lower or 'planetarium' in title_lower):\n            # Check upload date - looking for March 2018\n            upload_date = video.get('upload_date', '')\n            if upload_date.startswith('2018'):\n                filtered_results.append(video)\n    \n    return {'candidates': filtered_results, 'all_results': all_results}"}
